# Core service endpoints
ORCHESTRATOR_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ORCHESTRATOR_INTERNAL_URL=http://localhost:8000
SYNC_CORE_API_URL=http://localhost:8000
SYNCORE_API_URL=http://localhost:8000

# Syncore runtime mode
# native: sqlite + optional redis
# docker: postgres + redis (docker-compose overrides these explicitly)
SYNCORE_RUNTIME_MODE=native
SYNCORE_DB_BACKEND=sqlite
SQLITE_DB_PATH=.syncore/syncore.db
REDIS_REQUIRED=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_PASSWORD=agentos
POSTGRES_DSN=postgresql://agentos:agentos@localhost:5432/agentos

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM runtime (optional; local_echo works without external keys)
DEFAULT_LLM_PROVIDER=local_echo
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TIMEOUT_SECONDS=60
# OPENAI_API_KEY=add_only_in_local_env

# Autonomy loop (task idea -> route -> run -> digest)
AUTONOMY_ENABLED=false
AUTONOMY_POLL_INTERVAL_SECONDS=2.0
AUTONOMY_DEFAULT_MODEL=local_echo
AUTONOMY_MAX_RETRIES=2
AUTONOMY_RETRY_BASE_SECONDS=2.0

# Local service ports
ORCHESTRATOR_PORT=8000
WEB_PORT=3000

# Do not store provider keys in repo-tracked files.
# Add any sensitive values only in your local `.env`.
